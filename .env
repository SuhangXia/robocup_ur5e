<<<<<<< HEAD
# 注意：docker-compose 只识别 VAR=value 格式（不要写 export）
# 若在 shell 中 source 本文件，可手动在变量前加 export

# ---------------------------------------------------------------------------
# 模式一：本地 arm_gazebo Docker（先运行 arm_gazebo/docker 的 sudo ./run.bash）
# 与 arm_gazebo 同机时，roscore 在 localhost
# ---------------------------------------------------------------------------
ROS_MASTER_URI=http://127.0.0.1:11311
ROS_IP=127.0.0.1

# ---------------------------------------------------------------------------
# 模式二：VirtualBox VM 中的 Gazebo（取消下面两行注释并注释掉上面两行）
# ---------------------------------------------------------------------------
# ROS_MASTER_URI=http://172.27.144.129:11311
# ROS_IP=172.27.144.129
# 或 VM 在 192.168.56.101 时：
# ROS_MASTER_URI=http://192.168.56.101:11311
# ROS_IP=192.168.56.1

# GPU 设置（针对 NVIDIA RTX 5070 Ti）
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Docker Compose 项目名称
COMPOSE_PROJECT_NAME=robocup_ur5e

# 显示服务器（用于 GUI）
DISPLAY=:0

